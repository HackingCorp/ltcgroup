# =============================================
# LTC Group - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- PostgreSQL ---
POSTGRES_DB=ltcgroup
POSTGRES_USER=ltcgroup
POSTGRES_PASSWORD=ltcgroup_secret

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- pgAdmin ---
PGADMIN_EMAIL=admin@ltcgroup.site
PGADMIN_PASSWORD=admin

# --- Backend (FastAPI) ---
DATABASE_URL=postgresql+asyncpg://ltcgroup:ltcgroup_secret@localhost:5432/ltcgroup
ENVIRONMENT=development
ACCOUNTPE_API_URL=https://api.accountpe.com/v2
ACCOUNTPE_API_KEY=your_accountpe_api_key
ACCOUNTPE_JWT_SECRET=your_jwt_secret

# JWT Settings
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption
ENCRYPTION_KEY=your-encryption-key-change-in-production

# SMTP Email
SMTP_HOST=mail.ltcgroup.site
SMTP_PORT=587
SMTP_USER=noreply@ltcgroup.site
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@ltcgroup.site

# File Upload
UPLOAD_DIR=./uploads

# Payin API (Mobile Money - uses Swychr credentials)
PAYIN_API_URL=https://api.accountpe.com/api/payin
PAYIN_WEBHOOK_URL=
PAYIN_WEBHOOK_SECRET=your_payin_webhook_secret_here

# E-nkap Payment
ENKAP_API_URL=https://api-v2.enkap.cm
ENKAP_CONSUMER_KEY=your_enkap_consumer_key_here
ENKAP_CONSUMER_SECRET=your_enkap_consumer_secret_here
ENKAP_MERCHANT_CODE=
ENKAP_WEBHOOK_SECRET=your_enkap_webhook_secret_here

# S3 (optional, for production)
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Web (Next.js) - goes in web/.env.local ---
# DATABASE_URL=postgresql://ltcgroup:ltcgroup_secret@localhost:5432/ltcgroup
# SMTP_HOST=mail.ltcgroup.site
# SMTP_PORT=587

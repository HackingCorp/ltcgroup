# =============================================
# LTC Group - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git
#
# For production, use Docker Secrets instead:
#   ./scripts/setup_secrets.sh
#   docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# To generate strong secrets:
#   ./scripts/generate_secrets.sh

# --- Environment ---
ENVIRONMENT=development

# --- PostgreSQL ---
POSTGRES_DB=ltcgroup
POSTGRES_USER=ltcgroup
# REQUIRED: Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE-ME-RUN-generate_secrets.sh

# --- Redis ---
# REQUIRED: Generate with: openssl rand -base64 18
REDIS_PASSWORD=CHANGE-ME-RUN-generate_secrets.sh

# --- pgAdmin ---
PGADMIN_EMAIL=admin@ltcgroup.site
# REQUIRED: Generate with: openssl rand -base64 18
PGADMIN_PASSWORD=CHANGE-ME-RUN-generate_secrets.sh

# --- Backend (FastAPI) ---
# Swychr / AccountPE Virtual Card API
ACCOUNTPE_API_URL=https://api.accountpe.com/api/card/sandbox
SWYCHR_EMAIL=
SWYCHR_PASSWORD=

# JWT Settings
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-ME-RUN-generate_secrets.sh
# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE-ME-RUN-generate_secrets.sh

# SMTP Email
SMTP_HOST=mail.ltcgroup.site
SMTP_PORT=587
SMTP_USER=noreply@ltcgroup.site
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ltcgroup.site

# File Upload
UPLOAD_DIR=./uploads

# Payin API (Mobile Money - uses Swychr credentials)
PAYIN_API_URL=https://api.accountpe.com/api/payin
PAYIN_WEBHOOK_URL=
PAYIN_WEBHOOK_SECRET=

# Payout API
PAYOUT_API_URL=https://api.accountpe.com/api/payout

# E-nkap Payment
ENKAP_API_URL=https://api-v2.enkap.cm
ENKAP_CONSUMER_KEY=
ENKAP_CONSUMER_SECRET=
ENKAP_MERCHANT_CODE=
ENKAP_WEBHOOK_SECRET=

# KYC Verifier Microservice
KYC_VERIFIER_URL=http://kyc-verifier:8001
# REQUIRED: Generate with: openssl rand -hex 32
KYC_VERIFIER_API_KEY=CHANGE-ME-RUN-generate_secrets.sh

# S3 (optional, for production)
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LtcPay Backend Configuration

# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://ltcpay:ltcpay_secret@db:5432/ltcpay

# Redis
REDIS_URL=redis://redis:6379/1

# JWT / Secret Key
JWT_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001

# TouchPay Configuration
# SDK: sendPaymentInfos(payment_token, merchant_id, secure_code,
#   merchant_website, success_url, failed_url, amount, city, email, ...)
TOUCHPAY_MERCHANT_ID=LTCGR11789
TOUCHPAY_SECURE_CODE=your_secure_code_here
TOUCHPAY_MERCHANT_WEBSITE=ltcpay.com
TOUCHPAY_SECRET=
TOUCHPAY_SDK_URL=https://touchpay.gutouch.com/touchpayv2/script/prod_touchpay-0.0.1.js
TOUCHPAY_CALLBACK_URL=http://localhost:8001/webhooks/touchpay/callback
TOUCHPAY_RETURN_URL=http://localhost:8001/pay/return

# TouchPay API (lowercase aliases)
TOUCHPAY_API_URL=https://touchpay.gutouch.com/touchpayv2/api
TOUCHPAY_API_KEY=
TOUCHPAY_API_SECRET=
TOUCHPAY_WEBHOOK_SECRET=

# Payment settings
PAYMENT_CURRENCY=XAF
MIN_PAYMENT_AMOUNT=100.0
MAX_PAYMENT_AMOUNT=10000000.0
DEFAULT_CURRENCY=XAF
PAYMENT_LINK_EXPIRY_MINUTES=30

# Base URL (public-facing URL)
BASE_URL=http://localhost:8001
WEBHOOK_BASE_URL=http://localhost:8001
